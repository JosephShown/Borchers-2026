# Wordpress - ignore core, configuration, examples, uploads and logs.
# Based off https://github.com/github/gitignore/blob/main/WordPress.gitignore
# Version 1.1.0

# Core
# Note: if you want to stage/commit WP core files
# you can delete this whole section/until Configuration.
/wp-admin/
/wp-content/index.php
/wp-content/languages
/wp-content/plugins/index.php
/wp-content/themes/index.php
/wp-includes/
/index.php
/license.txt
/readme.html
/wp-*.php
/xmlrpc.php

# Configuration
wp-config.php
.user.ini
malcare-waf.php
.htaccess
nginx.conf
local-xdebuginfo.php

# Sitemap
sitemap.xml

# Example themes
/wp-content/themes/twenty*/

# Example plugin
/wp-content/plugins/hello.php
/wp-content/plugins/akismet*
/wp-content/plugins/jeffers*
/wp-content/plugins/all-in-one-wp*
/wp-content/plugins/malcare-security*
/wp-content/plugins/object-cache-pro
/wp-content/plugins/elementor
/wp-content/plugins/elementor-pro
/wp-content/plugins/advanced-custom-fields
/wp-content/plugins/advanced-custom-fields-pro
/wp-content/plugins/jetpack
/wp-content/plugins/creative-mail-by-constant-contact
/wp-content/plugins/ele-custom-skin
/wp-content/plugins/google-analytics-for-Wordpress
/wp-content/plugins/header-and-footer-scripts
/wp-content/plugins/optinmonster
/wp-content/plugins/wordpress-seo
/wp-content/plugins/code-snippets
/wp-content/plugins/wp-file-manager
/wp-content/plugins/wordpress-importer
/wp-content/plugins/wp-import-export-lite
/wp-content/plugins/wp-rollback


# Uploads
/wp-content/uploads/

# Log files
*.log

# Backups
/wp-content/ai1wm*
/wp-content/mc_data*
/wp-content/plugins/wp-security-toolset/.htaccess*

# Cache files
/wp-content/cache*
/wp-content/et-cache*
/wp-content/upgrade/*


# All plugins
#
# Note: If you wish to whitelist plugins,
# uncomment the next line
#/wp-content/plugins

# All themes
#
# Note: If you wish to whitelist themes,
# uncomment the next line
#/wp-content/themes